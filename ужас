host = '127.0.0.1'
port = 7777
Tcp = socket.socket(socket.AF_INET,socket.SOCK_STREAM)
Tcp.connect()
print("Подключился к серверу!")
# обмениваемся сообщениями
vvod = int(input("Вы: ")) # Спрашиваем, что отправить
while True:
    # Tcp.sendall(vvod)
    Tcp.send(vvod('utf-8')) # Кодируем русский текст в байты и отправляем
    if not vvod: # Если написали "пока" - выходим
        break
    otv = Tcp.recv(1024) # Получаем ответ от сервера
    perevod = int.from_bytes(otv, "big")
    print(f"Сервер: {perevod}") # переводим из байтов в русский текст и выводим
Tcp.close() # закрываем соединение
