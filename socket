host = '127.0.0.1' # 'localhost' можно так
port = 8888    # обязательно совпадает с клиентом
TCP = socket.socket(socket.AF_INET, socket.SOCK_STREAM) # TCP
TCP.bind((host, port))
TCP.listen()
print('Ожидание подключения')
to_client, adres = TCP.accept()
if to_client:
    print(f"Подключение от {adres}")
    while True:
        data = to_client.recv(1024)
        print(f"Получено от клиента: {data.decode('utf-8')}")
        to_client.send("Сервер прочитал сообщение".encode("utf-8"))
        to_client.close()



host ='127.0.0.1'
port = 8888
with socket.socket(socket.AF_INET,socket.SOCK_STREAM) as client:
    client.connect((host,port))
    print("Установка соединения с сервером")
    client.send(b'Hello,Server, I client')
    data = client.recv(1024)
print(f'Получено от сервера: {data.decode('utf-8')}')
client.close()




